<!-- SAFE ledger-chart fetch: 'List of Accounts' masters export. Replace the company name, then:
     curl.exe -s -m 30 -X POST -H "Content-Type: text/xml" --data-binary @list-of-accounts.xml http://localhost:9000
     Never use a TDL Collection over Ledger objects for this - it can hang the gateway. -->
<ENVELOPE>
 <HEADER><VERSION>1</VERSION><TALLYREQUEST>Export</TALLYREQUEST><TYPE>Data</TYPE><ID>List of Accounts</ID></HEADER>
 <BODY><DESC><STATICVARIABLES>
  <SVCURRENTCOMPANY>YOUR COMPANY NAME</SVCURRENTCOMPANY>
  <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
 </STATICVARIABLES></DESC></BODY>
</ENVELOPE>
